{
  "name": "@accounting-platform/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "lint": "node ../../scripts/lint-project.mjs",
    "test": "node --test ../../tests/*.test.mjs",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1 --port 3000",
    "db:generate": "prisma generate --schema ../../prisma/schema.prisma",
    "db:validate": "prisma validate --schema ../../prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --name init --schema ../../prisma/schema.prisma",
    "db:studio": "prisma studio --schema ../../prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "prisma": "6.19.3"
  }
}
